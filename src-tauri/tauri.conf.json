{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BambuMonitor",
  "version": "0.1.0",
  "identifier": "com.david.bambu-monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Bambu Monitor",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "visible": true,
        "devtools": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "title": "Bambu Monitor",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist": "dist"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
